# ============================================================
# STAKE CLONE - BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Your MongoDB Atlas connection string or local MongoDB URI
MONGO_URI="mongodb+srv://joshiom564_db_user:BCn1olJj0RIRRhoG@betfair.cvkceds.mongodb.net/betfair"

# --- Authentication ---
# A long, random secret string for signing JWT tokens
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# --- Betfair API (External - Zero-Leak Architecture) ---
# These credentials are ONLY used server-side, never exposed to the client.
# All Betfair requests MUST be routed through the UK proxy defined in services/betfairProxy.js
BETFAIR_APP_KEY=your_betfair_application_key
BETFAIR_SESSION_TOKEN=your_betfair_ession_token

# --- UK Proxy Configuration (Required for Betfair API Access) ---
# A UK-based proxy is REQUIRED to ensure all requests originate from
# an IP address permitted by Betfair's terms of service.
# Format: http://username:password@proxy-host:port
UK_PROXY_URL=http://your-proxy-user:your-proxy-pass@uk-proxy-host:port


